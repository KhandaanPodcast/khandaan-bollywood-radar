# Required for AI summaries and editorial suggestions.

# Optional: override listener_submissions.source with a public CSV or Google Sheet export.
# Leave blank to keep using listener_submissions.csv (or the source configured in sources.yaml).
# Example: https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
LISTENER_SUBMISSIONS_URL=

# Optional: the hosted URL used by the dashboard Share button.
# Example: https://your-name.github.io/khandaan-radar/
DASHBOARD_PUBLIC_URL=

# Required only when Reddit sources are enabled.
# Create a Reddit "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=khandaan-bollywood-radar/0.1 (contact: your-email@example.com)
